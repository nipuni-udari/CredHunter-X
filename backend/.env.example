# Copy this file to backend/.env for local development.
# Never commit a real API key.

CREDHUNTER_MONGODB_URI=
CREDHUNTER_MONGODB_DATABASE=credhunter_x
CREDHUNTER_REDIS_URL=redis://localhost:6379/0
CREDHUNTER_QUEUE_NAME=credhunter
# Comma-separated API keys. When empty, API authentication is disabled (local dev).
CREDHUNTER_API_KEYS=
OPENAI_API_KEY=
CREDHUNTER_OPENAI_MODEL=o4-mini
# The LLM pipeline (classify -> rank -> explain -> remediate) is ON by default.
# It only calls OpenAI when OPENAI_API_KEY above is set; without a key every stage
# is skipped and the deterministic engine runs. Uncomment to force it fully off:
# CREDHUNTER_LLM_ENABLED=false
# Individual stages (all default true): CREDHUNTER_LLM_RANK / _EXPLAIN / _REMEDIATE
CREDHUNTER_VALIDATION_ENABLED=false
CREDHUNTER_VALIDATION_NETWORK_ENABLED=false
