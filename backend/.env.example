CREDHUNTER_OPENAI_MODEL=o4-mini
CREDHUNTER_LLM_ENABLED=false
CREDHUNTER_VALIDATION_ENABLED=false
CREDHUNTER_VALIDATION_NETWORK_ENABLED=false
